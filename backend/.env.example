# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/agentops_studio

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:<password>@<host>:<port>

# ── JWT (generate with: openssl rand -base64 64) ──────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_string_minimum_32_chars_required
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string_32_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@agentops.studio

# ── AI Stack ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx

# ── Vapi (https://vapi.ai) ────────────────────────────────────────────────────
VAPI_API_KEY=xxxxxxxxxxxxxxxxxxxx
VAPI_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Exotel (https://exotel.com) ───────────────────────────────────────────────
EXOTEL_API_KEY=xxxxxxxxxxxxxxxxxxxx
EXOTEL_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
EXOTEL_SID=xxxxxxxxxxxxxxxxxxxx
